#table(
  columns: 1,
  stroke: (x, y) => (
    bottom: if y < 1 { 1.2pt } else { 0.6pt },
    left: none,
    right: none,
    top: none
  ),
  align: (auto),
  table.header([float]),
  [0.00],
  [100.0000001],
  [1.3572354],
  [1.0],
  [10000000.0],
  [1e\+20],
  [0.0005009],
  [None],
  [\-10.0000001],
  [\-1.3572354],
  [\-1.0],
  [\-10000000.0],
  [nan],
  [inf],
  [\-inf],
)
