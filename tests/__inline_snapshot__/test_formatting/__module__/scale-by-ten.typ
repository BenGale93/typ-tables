#table(
  columns: 1,
  stroke: (x, y) => (
    bottom: if y < 1 { 1.2pt } else { 0.6pt },
    left: none,
    right: none,
    top: none
  ),
  align: (auto),
  table.header([float]),
  [0.00],
  [1,000.00],
  [13.57],
  [10.00],
  [100,000,000.00],
  [1,000,000,000,000,000,000,000.00],
  [0.01],
  [None],
  [\-100.00],
  [\-13.57],
  [\-10.00],
  [\-100,000,000.00],
  [nan],
  [inf],
  [\-inf],
)
