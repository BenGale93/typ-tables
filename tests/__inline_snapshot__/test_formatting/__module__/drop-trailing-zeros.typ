#table(
  columns: 1,
  stroke: (x, y) => (
    bottom: if y < 1 { 1.2pt } else { 0.6pt },
    left: none,
    right: none,
    top: none
  ),
  align: (auto),
  table.header([float]),
  [0],
  [100],
  [1.36],
  [1],
  [10,000,000],
  [100,000,000,000,000,000,000],
  [0],
  [None],
  [\-10],
  [\-1.36],
  [\-1],
  [\-10,000,000],
  [nan],
  [inf],
  [\-inf],
)
