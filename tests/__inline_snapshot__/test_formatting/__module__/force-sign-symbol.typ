#table(
  columns: 1,
  stroke: (x, y) => (
    bottom: if y < 1 { 1.2pt } else { 0.6pt },
    left: none,
    right: none,
    top: none
  ),
  align: (auto),
  table.header([float]),
  [0.00],
  [\+100.00],
  [\+1.36],
  [\+1.00],
  [\+10,000,000.00],
  [\+100,000,000,000,000,000,000.00],
  [\+0.00],
  [None],
  [\-10.00],
  [\-1.36],
  [\-1.00],
  [\-10,000,000.00],
  [nan],
  [inf],
  [\-inf],
)
