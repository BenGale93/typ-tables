#table(
  columns: 1,
  stroke: (x, y) => (
    bottom: if y < 1 { 1.2pt } else { 0.6pt },
    left: none,
    right: none,
    top: none
  ),
  align: (auto),
  table.header([float]),
  [0.00000],
  [100.00000],
  [1.35724],
  [1.00000],
  [10,000,000.00000],
  [100,000,000,000,000,000,000.00000],
  [0.00050],
  [None],
  [\-10.00000],
  [\-1.35724],
  [\-1.00000],
  [\-10,000,000.00000],
  [nan],
  [inf],
  [\-inf],
)
