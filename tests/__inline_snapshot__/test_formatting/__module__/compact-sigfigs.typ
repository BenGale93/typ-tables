#table(
  columns: 1,
  stroke: (x, y) => (
    bottom: if y < 1 { 1.2pt } else { 0.6pt },
    left: none,
    right: none,
    top: none
  ),
  align: (auto),
  table.header([float]),
  [0],
  [100],
  [1.36],
  [1.00],
  [10.0M],
  [100,000Q],
  [0.000501],
  [None],
  [\-10.0],
  [\-1.36],
  [\-1.00],
  [\-10.0M],
  [nan],
  [inf],
  [\-inf],
)
