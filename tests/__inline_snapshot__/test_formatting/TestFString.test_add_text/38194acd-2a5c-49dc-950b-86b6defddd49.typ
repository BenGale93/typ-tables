#table(
  columns: 2,
  stroke: none,
  align: (auto, auto),
  table.header(
    [string], [int]
  ),
table.hline(stroke: 1.2pt),
  [^a\*], [10],
  table.hline(stroke: 0.6pt),
  [^b\*], [10000],
  table.hline(stroke: 0.6pt),
  [^c\*], [1000000],
  table.hline(stroke: 0.6pt),
  [None], [None],
  table.hline(stroke: 0.6pt),
)
