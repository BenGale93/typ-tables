#table(
  columns: 1,
  stroke: none,
  align: (auto),
  table.header[#table.cell(stroke: (bottom: 1.2pt))[date]],
  [#table.cell(stroke: (bottom: 0.6pt))[2000-Q%q]],
  [#table.cell(stroke: (bottom: 0.6pt))[2023-Q%q]],
  [#table.cell(stroke: (bottom: 0.6pt))[1999-Q%q]],
  [#table.cell(stroke: (bottom: 0.6pt))[2024-Q%q]],
  [#table.cell(stroke: (bottom: 0.6pt))[None]],
)
