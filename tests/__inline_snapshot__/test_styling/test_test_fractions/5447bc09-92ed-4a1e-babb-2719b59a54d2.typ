#table(
  columns: 1,
  stroke: none,
  align: (auto),
  table.hline(stroke: 1.2pt),
  table.header(
    table.cell(
      colspan: 1,
      align: center,
      [Table Header],
    ),
  ),
  table.hline(stroke: 1.2pt),
  table.header([Fractions]),
  table.hline(stroke: 1.2pt),
  text(
  fractions: true,
)[1\/2],
  table.hline(stroke: 0.6pt),
  text(
  fractions: true,
)[1\/3],
  table.hline(stroke: 0.6pt),
)
